# ============================================================
#  GitPulse — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to GitHub — it contains secret keys!
# ============================================================

# ------ Server ------
# The port your Express server will listen on locally.
PORT=8080

# Set to "production" when deploying to a real server.
NODE_ENV=development

# ------ Google Gemini AI ------
# Get this from https://aistudio.google.com/app/apikey
# This key lets GitPulse call Gemini to review code.
GEMINI_API_KEY=AIza-your-key-here

# ------ GitHub ------
# A Personal Access Token so the MCP server can read/write to GitHub.
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (read + write, which includes pull requests)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-token-here

# A secret string YOU make up. GitHub uses it to sign every webhook
# payload it sends, so GitPulse can verify the request is real.
# Use any random string, e.g. run:  openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-random-secret-string-here
